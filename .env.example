# Ada iMessage Agent - Environment Variables
# This agent connects to the same InsForge backend as the iOS app.

# === Required ===
OWNER_PHONE=+1234567890     # Your phone number - Ada only responds to this

# === InsForge Backend (same as iOS app) ===
# These match EXPO_PUBLIC_INSFORGE_URL and EXPO_PUBLIC_INSFORGE_ANON_KEY from the iOS app.
INSFORGE_URL=https://your-insforge-instance.com
INSFORGE_ANON_KEY=your_anon_key

# The Ada user account this agent authenticates as.
# Items created by the iMessage agent will appear in this user's iOS app.
INSFORGE_USER_EMAIL=you@example.com
INSFORGE_USER_PASSWORD=your_password

# === API Keys (local fallback when InsForge is unreachable) ===
ANTHROPIC_API_KEY=           # Claude Sonnet - Ada's brain (Layer 2)
OPENAI_API_KEY=              # GPT-4o-mini - intent classifier (Layer 1)
SUPERMEMORY_API_KEY=         # Persistent memory (RAG) - same key as iOS app
COMPOSIO_API_KEY=            # Composio - calendar, tasks, reminders
JINA_API_KEY=                # Jina Reader - URL extraction and summarization

# === Optional: Group Chats ===
WATCH_GROUPS=false           # Set to "true" to enable group chat monitoring
WATCHED_GROUP_IDS=chatId1,chatId2  # Comma-separated iMessage group chat IDs

# === Optional: Sync Server ===
SYNC_SERVER_PORT=3001        # Port for the iOS app sync endpoint

# === Optional: Identity ===
ADA_NAME=Ada                 # Ada's display name
NODE_ENV=production          # Set to "development" for debug logging
